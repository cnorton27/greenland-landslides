import rasterio as rio
import pygmtsar as pg


# Step 1: Phase unwrapping

pipeline = pg.Pipeline("data")

# Compute, mask, and unwrap all pairs seamlessly in one command
# This automatically calls SNAPHU across multi-core processors

pipeline.unwrap(
    threshold=0.2,       # Masks out any pixels with coherence below 0.2
    grid=True,           # Uses geo-referenced grid arrays
    method='snaphu'      # Uses the SNAPHU engine configuration
)

